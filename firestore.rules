rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Admins collection ───────────────────────────────────────────────────
    // The `admins` collection stores documents keyed by Firebase UID.
    // Document structure: { role: "admin" }
    //
    // - Any authenticated user can READ their own admin document (so the
    //   frontend can check whether the current user is an admin).
    // - Only existing admins can WRITE (add/remove other admins).
    //   This prevents self-promotion: a non-admin cannot create their own doc.
    match /admins/{uid} {
      allow read:  if request.auth != null && request.auth.uid == uid;
      allow write: if request.auth != null
                   && exists(/databases/$(database)/documents/admins/$(request.auth.uid))
                   && get(/databases/$(database)/documents/admins/$(request.auth.uid)).data.role == 'admin';
    }

    // ─── Events collection ───────────────────────────────────────────────────
    match /events/{eventId} {

      // Public learners can read events (no auth required)
      allow read: if true;

      // Only admin users may create or update events (schema validation also applied)
      allow create, update: if isAdmin() && isValidEvent(request.resource.data);

      // Only admin users may delete events
      allow delete: if isAdmin();
    }

    // ─── Helper: check caller is an admin ────────────────────────────────────
    function isAdmin() {
      return request.auth != null
        && exists(/databases/$(database)/documents/admins/$(request.auth.uid))
        && get(/databases/$(database)/documents/admins/$(request.auth.uid)).data.role == 'admin';
    }

    // ─── Helper: validate event document schema ───────────────────────────────
    function isValidEvent(data) {
      return data.title is string
        && data.title.size() > 0
        // If present, start/end dates must be string or null
        && (!('startDate' in data) || data.startDate == null || data.startDate is string)
        && (!('endDate'   in data) || data.endDate   == null || data.endDate   is string)
        // Start date must be before end date when both are non-null strings
        && (
          !('startDate' in data) ||
          !('endDate'   in data) ||
          data.startDate == null ||
          data.endDate   == null ||
          (data.startDate is string && data.endDate is string && data.startDate < data.endDate)
        )
        // Registration date chronology
        && (
          !('registrationOpenDate'  in data) ||
          !('registrationCloseDate' in data) ||
          data.registrationOpenDate  == null ||
          data.registrationCloseDate == null ||
          (data.registrationOpenDate  is string && data.registrationOpenDate  == '') ||
          (data.registrationCloseDate is string && data.registrationCloseDate == '') ||
          (data.registrationOpenDate  is string &&
           data.registrationCloseDate is string &&
           data.registrationOpenDate  < data.registrationCloseDate)
        )
        && (!('registrationOpenDate'  in data) || data.registrationOpenDate  == null || data.registrationOpenDate  is string)
        && (!('registrationCloseDate' in data) || data.registrationCloseDate == null || data.registrationCloseDate is string);
    }
  }
}
